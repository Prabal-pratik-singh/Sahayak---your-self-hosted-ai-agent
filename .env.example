# Copy this file to ".env" and fill it in. docker-compose reads it automatically.

# AI PROVIDERS — all optional now: users can bring their own keys (BYOK) in
# Settings → AI engine keys. Server keys below become the shared default.
# Claude:  https://console.anthropic.com
ANTHROPIC_API_KEY=
# ChatGPT: https://platform.openai.com/api-keys
#OPENAI_API_KEY=
# Gemini:  https://aistudio.google.com/apikey
#GEMINI_API_KEY=
# Groq (generous free tier): https://console.groq.com/keys
#GROQ_API_KEY=
#GROQ_MODEL=openai/gpt-oss-120b
# GitHub Models (free with any GitHub account): https://github.com/settings/tokens
#GITHUB_MODELS_KEY=
# Cerebras (free tier): https://cloud.cerebras.ai
#CEREBRAS_API_KEY=
# Mistral (free tier): https://console.mistral.ai
#MISTRAL_API_KEY=
# OpenRouter (free models, CHAT-ONLY — no tools): https://openrouter.ai/keys
#OPENROUTER_API_KEY=

# STRONGLY RECOMMENDED — any long random string (40+ characters).
# Protects logins and encrypts stored email/LinkedIn credentials.
APP_SECRET=

# --- Optional ---

# Which models to use per provider
#ANTHROPIC_MODEL=claude-sonnet-5
#OPENAI_MODEL=gpt-5-mini
#GEMINI_MODEL=gemini-2.5-flash

# Which configured provider answers by default: anthropic | openai | gemini
#APP_DEFAULT_AI=anthropic

# Database password (change it for anything beyond local use)
#DB_PASSWORD=agent

# Set to false to stop strangers from creating accounts on your server
#APP_ALLOW_SIGNUPS=true

# Only needed for the LinkedIn integration (see README "Connect LinkedIn")
#LINKEDIN_CLIENT_ID=
#LINKEDIN_CLIENT_SECRET=

# Only needed for the GitHub integration — create an OAuth app at
# https://github.com/settings/developers (see README "Connect GitHub").
# NOTE: separate from GITHUB_MODELS_KEY above (that's the AI provider).
#GITHUB_OAUTH_CLIENT_ID=
#GITHUB_OAUTH_CLIENT_SECRET=

# Only needed for the Google Calendar integration — create a free Google Cloud
# project with the Calendar API enabled (see README "Connect Google Calendar").
#GOOGLE_OAUTH_CLIENT_ID=
#GOOGLE_OAUTH_CLIENT_SECRET=

# Your timezone, so "tomorrow 6 PM" means YOUR 6 PM when running in Docker
#TZ=Asia/Kolkata

# Only change these when hosting on a real domain
#APP_FRONTEND_URL=http://localhost:5173
#APP_BASE_URL=http://localhost:8080
