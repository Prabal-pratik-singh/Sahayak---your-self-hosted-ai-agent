# Copy this file to ".env" and fill it in. docker-compose reads it automatically.

# AI PROVIDERS — set at least ONE key; set several and users can pick
# their brain from a dropdown in the chat.
# Claude:  https://console.anthropic.com
ANTHROPIC_API_KEY=
# ChatGPT: https://platform.openai.com/api-keys
#OPENAI_API_KEY=
# Gemini:  https://aistudio.google.com/apikey
#GEMINI_API_KEY=

# STRONGLY RECOMMENDED — any long random string (40+ characters).
# Protects logins and encrypts stored email/LinkedIn credentials.
APP_SECRET=

# --- Optional ---

# Which models to use per provider
#ANTHROPIC_MODEL=claude-sonnet-5
#OPENAI_MODEL=gpt-5-mini
#GEMINI_MODEL=gemini-2.5-flash

# Which configured provider answers by default: anthropic | openai | gemini
#APP_DEFAULT_AI=anthropic

# Database password (change it for anything beyond local use)
#DB_PASSWORD=agent

# Set to false to stop strangers from creating accounts on your server
#APP_ALLOW_SIGNUPS=true

# Only needed for the LinkedIn integration (see README "Connect LinkedIn")
#LINKEDIN_CLIENT_ID=
#LINKEDIN_CLIENT_SECRET=

# Your timezone, so "tomorrow 6 PM" means YOUR 6 PM when running in Docker
#TZ=Asia/Kolkata

# Only change these when hosting on a real domain
#APP_FRONTEND_URL=http://localhost:5173
#APP_BASE_URL=http://localhost:8080
